---
import ContentLayout from '../../layouts/ContentLayout.astro';
import { getCollection, render } from 'astro:content';

const posts = await getCollection('guides');
const troublePost = posts.find(p => p.data.slug === 'troubleshooting');

let Content = null;
if (troublePost) {
  const rendered = await render(troublePost);
  Content = rendered.Content;
}
---

<ContentLayout
  title="Troubleshooting"
  description="Common issues and solutions for Lightning Piggy"
>
  {Content && <Content />}
</ContentLayout>
