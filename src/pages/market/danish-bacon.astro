---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Danish Bacon"
  description="Buy Lightning Piggy hardware with Bitcoin over Lightning."
>
  <!-- Hero -->
  <section class="py-10 md:py-14 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/market" class="inline-flex items-center gap-1 text-sm text-gray-500 hover:text-pink mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Market
      </a>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3 tracking-tight">Danish Bacon 🇩🇰</h1>
      <p class="text-lg text-gray-600 max-w-xl mx-auto leading-relaxed">
Small hands, big help!
Pick your favorites and leave the rest to us — our youngest team member will help pack your order with extra care. Make sure to select the correct shipping option at checkout!
      </p>
     </div>
  </section>

  <!-- BTCPay iframe -->
  <section class="border-t border-gray-100 w-full">
    <iframe
      src="https://btcpay.ideasarelikeflames.org/apps/2tGWUJdP3FrKb7aFg5qEQTXrzB4z/pos"
      sandbox="allow-scripts allow-same-origin allow-forms allow-popups"
      allow="payment"
      loading="lazy"
      title="Danish Bacon Shop - BTCPay Server"
      class="shop-iframe"
    ></iframe>
  </section>
</BaseLayout>

<style>
  .shop-iframe {
    display: block;
    width: 100%;
    min-height: calc(100vh - 280px);
    border: none;
  }
</style>
