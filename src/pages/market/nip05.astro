---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Lightning Piggy Nostr Handles"
  description="Get yourname@lightningpiggy.com as your Nostr identity. Pay what you want with Bitcoin."
>

  <!-- Hero -->
  <div class="relative overflow-hidden bg-gradient-to-b from-gray-900 to-gray-800 text-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-16 text-center">
      <a href="/market" class="inline-flex items-center gap-1 text-sm text-gray-400 hover:text-pink mb-6 transition-colors">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Market
      </a>
      <h1 class="text-4xl md:text-5xl font-bold mb-6">Lightning Piggy Nostr Handles</h1>
      <p class="text-xl text-gray-300 leading-relaxed max-w-2xl mx-auto">
        Get <span class="text-pink font-semibold">yourname@lightningpiggy.com</span> as your
        Nostr identity. Verified, memorable, and powered by the Lightning Piggy community.
      </p>
    </div>
  </div>

  <!-- Purchase Form -->
  <section class="py-10 md:py-16 bg-white">
    <div class="max-w-xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Choose Your Handle</h2>
        <p class="text-lg text-gray-600 max-w-xl mx-auto">
          Pick a username, paste your npub, and pay what you want. Your NIP-05 handle will be live within minutes.
        </p>
      </div>

      <div class="bg-white rounded-2xl border border-gray-200 p-6 md:p-8">
        <form id="nip05-form" class="space-y-6">

          <!-- Handle input -->
          <div>
            <label for="nip05-handle" class="block text-sm font-semibold text-gray-900 mb-1.5">
              Handle
            </label>
            <div class="flex items-stretch">
              <input
                type="text"
                id="nip05-handle"
                name="handle"
                required
                placeholder="yourname"
                autocapitalize="none"
                autocomplete="off"
                spellcheck="false"
                class="flex-1 px-4 py-3 rounded-l-xl border border-r-0 border-gray-200 focus:border-pink focus:ring-2 focus:ring-pink/20 outline-none transition-all text-gray-900 placeholder-gray-400"
              />
              <span class="inline-flex items-center px-4 py-3 rounded-r-xl border border-l-0 border-gray-200 bg-gray-50 text-gray-500 text-sm font-medium whitespace-nowrap">
                @lightningpiggy.com
              </span>
            </div>
            <p id="handle-status" class="text-sm mt-1.5 h-5"></p>
          </div>

          <!-- npub input -->
          <div>
            <label for="nip05-npub" class="block text-sm font-semibold text-gray-900 mb-1.5">
              Nostr npub
            </label>
            <input
              type="text"
              id="nip05-npub"
              name="npub"
              required
              placeholder="npub1..."
              autocapitalize="none"
              autocomplete="off"
              spellcheck="false"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-pink focus:ring-2 focus:ring-pink/20 outline-none transition-all text-gray-900 placeholder-gray-400"
            />
            <p id="npub-status" class="text-sm mt-1.5 h-5"></p>
          </div>

          <!-- Amount selection -->
          <div>
            <label class="block text-sm font-semibold text-gray-900 mb-3">
              Amount (USD) — pay what you want
            </label>
            <div class="grid grid-cols-3 gap-2 mb-3" id="preset-amounts">
              <button type="button" data-amount="5"
                class="preset-btn py-2.5 rounded-xl border-2 border-pink bg-pink/5 text-pink font-semibold text-sm transition-all">$5</button>
              <button type="button" data-amount="21"
                class="preset-btn py-2.5 rounded-xl border-2 border-gray-200 text-gray-700 font-semibold text-sm hover:border-pink hover:text-pink transition-all">$21</button>
              <button type="button" data-amount="50"
                class="preset-btn py-2.5 rounded-xl border-2 border-gray-200 text-gray-700 font-semibold text-sm hover:border-pink hover:text-pink transition-all">$50</button>
            </div>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-medium">$</span>
              <input
                type="number"
                id="nip05-amount"
                name="amount"
                min="1"
                step="any"
                value="5"
                required
                placeholder="Enter amount"
                class="w-full pl-8 pr-4 py-3 rounded-xl border border-gray-200 focus:border-pink focus:ring-2 focus:ring-pink/20 outline-none transition-all text-gray-900 placeholder-gray-400"
              />
            </div>
          </div>

          <!-- Submit button -->
          <button
            type="submit"
            id="nip05-submit"
            class="w-full py-3 px-6 bg-pink text-white font-semibold rounded-xl hover:bg-pink/90 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <span class="btn-text">Get NIP-05 Handle</span>
            <span class="btn-loading hidden">
              <svg class="animate-spin h-5 w-5 mx-auto" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </span>
          </button>

          <!-- Error message -->
          <p id="nip05-error" class="text-sm text-red-500 text-center hidden"></p>

        </form>
      </div>

      <p class="text-sm text-gray-400 mt-6 text-center">
        Payments are processed through our self-hosted BTCPay Server. Your handle will be live after the next site build (~1-2 minutes).
      </p>
    </div>
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var CHECK_ENDPOINT = '/.netlify/functions/check-nip05';
      var INVOICE_ENDPOINT = '/.netlify/functions/create-nip05-invoice';

      var form = document.getElementById('nip05-form');
      var handleInput = document.getElementById('nip05-handle');
      var npubInput = document.getElementById('nip05-npub');
      var amountInput = document.getElementById('nip05-amount');
      var submitBtn = document.getElementById('nip05-submit');
      var btnText = submitBtn.querySelector('.btn-text');
      var btnLoading = submitBtn.querySelector('.btn-loading');
      var errorEl = document.getElementById('nip05-error');
      var statusEl = document.getElementById('handle-status');
      var npubStatusEl = document.getElementById('npub-status');
      var presetBtns = document.querySelectorAll('.preset-btn');

      var debounceTimer;
      var handleAvailable = false;

      function setActivePreset(activeBtn) {
        presetBtns.forEach(function (btn) {
          btn.classList.remove('border-pink', 'bg-pink/5', 'text-pink');
          btn.classList.add('border-gray-200', 'text-gray-700');
        });
        if (activeBtn) {
          activeBtn.classList.remove('border-gray-200', 'text-gray-700');
          activeBtn.classList.add('border-pink', 'bg-pink/5', 'text-pink');
        }
      }

      presetBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          amountInput.value = btn.getAttribute('data-amount');
          setActivePreset(btn);
          errorEl.classList.add('hidden');
        });
      });

      amountInput.addEventListener('input', function () {
        var val = amountInput.value;
        var matched = null;
        presetBtns.forEach(function (btn) {
          if (btn.getAttribute('data-amount') === val) matched = btn;
        });
        setActivePreset(matched);
      });

      npubInput.addEventListener('input', function () {
        var val = npubInput.value.trim();
        npubStatusEl.className = 'text-sm mt-1.5 h-5';
        if (!val) {
          npubStatusEl.textContent = '';
        } else if (!val.startsWith('npub')) {
          npubStatusEl.classList.add('text-red-500');
          npubStatusEl.textContent = '✗ Must start with npub';
        } else if (/^npub1[a-z0-9]{58}$/.test(val)) {
          npubStatusEl.classList.add('text-green-600');
          npubStatusEl.textContent = '✓ Valid npub';
        } else {
          npubStatusEl.classList.add('text-gray-400');
          npubStatusEl.textContent = 'Keep typing…';
        }
      });

      function showStatus(type, message) {
        statusEl.textContent = message;
        statusEl.className = 'text-sm mt-1.5 h-5';
        if (type === 'available') {
          statusEl.classList.add('text-green-600');
          statusEl.textContent = '✓ ' + message;
        } else if (type === 'taken' || type === 'reserved' || type === 'invalid') {
          statusEl.classList.add('text-red-500');
          statusEl.textContent = '✗ ' + message;
        } else if (type === 'checking') {
          statusEl.classList.add('text-gray-400');
        } else {
          statusEl.textContent = '';
        }
      }

      function showError(msg) {
        errorEl.textContent = msg;
        errorEl.classList.remove('hidden');
      }

      function setLoading(loading) {
        submitBtn.disabled = loading;
        if (loading) {
          btnText.classList.add('hidden');
          btnLoading.classList.remove('hidden');
        } else {
          btnText.classList.remove('hidden');
          btnLoading.classList.add('hidden');
        }
      }

      function checkAvailability(handle) {
        showStatus('checking', 'Checking availability…');
        handleAvailable = false;

        fetch(CHECK_ENDPOINT + '?handle=' + encodeURIComponent(handle))
          .then(function (res) { return res.json(); })
          .then(function (data) {
            // Make sure the input hasn't changed since we started the check
            if (handleInput.value.trim().toLowerCase() !== handle) return;

            if (data.available) {
              handleAvailable = true;
              showStatus('available', 'Available!');
            } else if (data.reason === 'taken') {
              showStatus('taken', 'Already taken — please choose a different name');
            } else if (data.reason === 'reserved') {
              showStatus('reserved', 'Reserved — please choose a different name');
            } else {
              showStatus('invalid', 'Invalid format');
            }
          })
          .catch(function () {
            showStatus('', '');
          });
      }

      handleInput.addEventListener('input', function () {
        clearTimeout(debounceTimer);
        handleAvailable = false;
        errorEl.classList.add('hidden');

        var handle = handleInput.value.trim().toLowerCase();
        if (!handle) {
          showStatus('', '');
          return;
        }

        // Client-side format check
        if (!/^[a-z0-9][a-z0-9_-]{0,30}[a-z0-9]$|^[a-z0-9]$/.test(handle)) {
          showStatus('invalid', 'Use lowercase letters, numbers, hyphens, underscores');
          return;
        }

        debounceTimer = setTimeout(function () {
          checkAvailability(handle);
        }, 500);
      });

      form.addEventListener('submit', function (e) {
        e.preventDefault();
        errorEl.classList.add('hidden');

        var handle = handleInput.value.trim().toLowerCase();
        var npub = npubInput.value.trim();
        var amount = parseFloat(amountInput.value);

        // Validate handle
        if (!handle) {
          showError('Please enter a handle.');
          return;
        }
        if (!/^[a-z0-9][a-z0-9_-]{0,30}[a-z0-9]$|^[a-z0-9]$/.test(handle)) {
          showError('Invalid handle format. Use lowercase letters, numbers, hyphens, and underscores.');
          return;
        }
        if (!handleAvailable) {
          showError('Please wait for the availability check, or choose a different handle.');
          return;
        }

        // Validate npub
        if (!npub) {
          showError('Please enter your Nostr npub.');
          return;
        }
        if (!/^npub1[a-z0-9]{58}$/.test(npub)) {
          showError('Invalid npub format. It should start with npub1 and be 63 characters long.');
          return;
        }

        // Validate amount
        if (!amount || amount < 1) { // TODO: restore to 5 after testing
          showError('Minimum amount is $1.');
          return;
        }

        setLoading(true);

        fetch(INVOICE_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            handle: handle,
            npub: npub,
            amount: String(amount)
          })
        })
          .then(function (response) {
            if (response.status === 409) {
              throw new Error('This handle was just taken. Please choose a different one.');
            }
            if (!response.ok) {
              return response.json().then(function (data) {
                throw new Error(data.error || 'Failed to create invoice.');
              });
            }
            return response.json();
          })
          .then(function (data) {
            if (data.checkoutLink) {
              window.location.href = data.checkoutLink;
            } else {
              throw new Error('No checkout link in response.');
            }
          })
          .catch(function (err) {
            console.error('NIP-05 purchase error:', err);
            showError(err.message || 'Something went wrong. Please try again.');
            setLoading(false);
            // Re-check availability since it may have changed
            checkAvailability(handle);
          });
      });
    });
  </script>

  <!-- What is NIP-05? -->
  <section class="py-10 md:py-16 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-8 text-center">What is NIP-05?</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        <div class="flex items-start gap-4">
          <span class="text-pink font-bold text-xl mt-0.5">→</span>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Verified identity</h3>
            <p class="text-gray-600 text-sm">NIP-05 links your Nostr public key to a human-readable address, so people know it's really you.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-pink font-bold text-xl mt-0.5">→</span>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Easy to share</h3>
            <p class="text-gray-600 text-sm">Instead of sharing a long npub, just tell people your handle (you@lightningpiggy.com) — like an email address for Nostr.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-pink font-bold text-xl mt-0.5">→</span>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Client support</h3>
            <p class="text-gray-600 text-sm">Nostr clients like Primal, Damus, and Amethyst display a verified checkmark next to NIP-05 handles.</p>
          </div>
        </div>
        <div class="flex items-start gap-4">
          <span class="text-pink font-bold text-xl mt-0.5">→</span>
          <div>
            <h3 class="font-bold text-gray-900 mb-1">Support the project</h3>
            <p class="text-gray-600 text-sm">Your contribution helps fund Lightning Piggy development, education resources, and community events.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
