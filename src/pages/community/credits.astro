                  {profile.url ? (
                    <a href={profile.url} target="_blank" rel="noopener noreferrer" class="block">
                      <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-gray-100 overflow-hidden relative">
                        {profile.avatar ? (
                          <img
                            src={profile.avatar}
                            alt={profile.displayName}
                            class="w-full h-full object-cover"
                            onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                          />
                        ) : null}
                        <div class="w-full h-full bg-pink/10 flex items-center justify-center text-pink text-lg font-bold" style={profile.avatar ? "display: none;" : ""}>
                          {profile.displayName.charAt(0).toUpperCase()}
                        </div>
                      </div>
                      <h3 class="font-semibold text-gray-900 group-hover:text-pink transition-colors text-sm">
                        {person.isBitcoinKid && <span class="mr-1">⭐️</span>}
                        {profile.displayName}
                      </h3>
                      <p class="text-xs text-gray-500 mt-1">{person.contribution}</p>
                    </a>
                  ) : (
                    <>
                      <div class="w-14 h-14 mx-auto mb-3 rounded-full bg-pink/10 flex items-center justify-center text-pink text-lg font-bold">
                        {profile.displayName.charAt(0).toUpperCase()}
