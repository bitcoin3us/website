---
import BaseLayout from '../../layouts/BaseLayout.astro';
import creditsData from '../../data/credits.json';

// Helper to check if URL is a personal website (not a social profile)
function isWebsiteUrl(url?: string): boolean {
  if (!url) return false;
  // Social profile patterns that should NOT show globe icon
  const socialPatterns = [
    /twitter\.com\//i,
    /x\.com\//i,
    /njump\.me\//i,
    /github\.com\//i,
    /nostr\.band\//i,
    /primal\.net\//i,
    /geyser\.fund\/project\//i,  // Geyser project pages are like social profiles
  ];
  return !socialPatterns.some(pattern => pattern.test(url));
}

// Helper to extract username and avatar from various URL formats
function parseProfile(name: string, url?: string, avatar?: string, nostrUrl?: string, xUrl?: string, githubUrl?: string): { displayName: string; username: string; avatar: string; url?: string; websiteUrl?: string; nostrUrl?: string; xUrl?: string; githubUrl?: string } {
  const cleanName = name.replace(/^⭐️\s*/, '').trim();

  const websiteUrl = isWebsiteUrl(url) ? url : undefined;

  // If avatar is explicitly provided, use it
  if (avatar) {
    return { displayName: cleanName, username: cleanName, avatar, url, websiteUrl, nostrUrl, xUrl, githubUrl };
  }

  if (!url) {
    return { displayName: cleanName, username: cleanName, avatar: '', websiteUrl, nostrUrl, xUrl, githubUrl };
  }

  // Twitter URLs - try to get avatar
  const twitterMatch = url.match(/twitter\.com\/([^\/\?]+)/i) || url.match(/x\.com\/([^\/\?]+)/i);
  if (twitterMatch) {
    return {
      displayName: cleanName,
      username: `@${twitterMatch[1]}`,
      avatar: `https://unavatar.io/twitter/${twitterMatch[1]}`,
      url,
      websiteUrl,
      nostrUrl,
      xUrl,
      githubUrl
    };
  }

  // Fallback - no avatar
  return {
    displayName: cleanName,
    username: cleanName,
    avatar: '',
    url,
    websiteUrl,
    nostrUrl,
    xUrl,
    githubUrl
  };
}

const { coreTeam = [], contributors = [], specialThanks = [] } = creditsData;
// Merge contributors and specialThanks into a single array
const allContributors = [...contributors, ...specialThanks];
---

<BaseLayout title="Credits" description="The team and contributors behind Lightning Piggy">
  <section class="py-12 md:py-16">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <header class="mb-12 text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Credits</h1>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          We extend our heartfelt gratitude to everyone who has played a role in bringing this little piggy to market.
        </p>
      </header>

      <!-- Core Team -->
      {coreTeam.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-bold text-gray-900 mb-2">Lightning Piggy Foundation</h2>
          <p class="text-gray-600 mb-6">The Foundation team — stewarding the project's development and keeping Lightning Piggy free, open source, and accessible to all.</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
            {coreTeam.map((person) => {
              const profile = parseProfile(person.name, person.url, person.avatar, person.nostrUrl, person.xUrl, person.githubUrl);
              return (
                <div
                  class={`bg-white rounded-xl p-4 text-center transition-all ${profile.url ? 'hover:shadow-lg group cursor-pointer' : ''} ${person.isBitcoinKid ? 'ring-2 ring-yellow-400' : ''}`}
