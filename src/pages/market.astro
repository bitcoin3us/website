---
import ContentLayout from '../layouts/ContentLayout.astro';
import Button from '../components/ui/Button.astro';
import vendorsData from '../data/vendors.json';

const { vendors = [] } = vendorsData;

const shopTypeLabels: Record<string, string> = {
  online: '🌐 Online',
  physical: '🏪 Physical',
  both: '🌐🏪 Online & Physical',
};
---

<ContentLayout
  title="Market"
  description="This little piggy went to market… Buy a Lightning Piggy directly from the project team or from one of these awesome vendors below. Making sats the savings standard for every child is a team effort! If you run a store and would like to stock Lightning Piggy, we’d love to hear from you."
  heroImage="/images/pages/robotechy-pigs.jpeg"
>
  {vendors.length > 0 && (
    <div class="grid md:grid-cols-2 gap-6 my-8 not-prose">
      {vendors.map((vendor) => {
        const isInternal = vendor.url?.startsWith('/');
        return (
        <a
          href={vendor.url}
          {...(!isInternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
          class="block p-6 bg-white rounded-xl border border-gray-200 hover:border-pink hover:shadow-lg transition-all"
        >
          <div class="flex items-start gap-4">
            <div class="w-14 h-14 bg-gray-100 rounded-lg flex-shrink-0 overflow-hidden flex items-center justify-center">
              {vendor.logo ? (
                <img
                  src={vendor.logo}
                  alt={vendor.name}
                  class="w-full h-full object-cover"
                  onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                />
              ) : null}
              <div
                class="w-full h-full bg-pink/10 flex items-center justify-center text-pink text-xl font-bold"
                style={vendor.logo ? "display: none;" : ""}
              >
                {vendor.name.charAt(0).toUpperCase()}
              </div>
            </div>
            <div class="flex-1">
              <div class="flex items-center gap-2">
                <h3 class="font-bold text-gray-900">{vendor.name}</h3>
                <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 text-gray-500">
                  {shopTypeLabels[vendor.shopType] || shopTypeLabels.online}
                </span>
              </div>
              <p class="text-sm text-gray-500">
                {vendor.country}
                {vendor.shippingRegions && vendor.shippingRegions.length > 0 && (
                  <span> · Ships to {vendor.shippingRegions.join(', ')}</span>
                )}
              </p>
              {vendor.description && (
                <p class="text-sm text-gray-600 mt-2">{vendor.description}</p>
              )}
              {(vendor.nostrUrl || vendor.xUrl) && (
                <div class="flex gap-3 mt-2">
                  {vendor.nostrUrl && (
                    <span
                      class="text-gray-400 hover:text-purple-600 transition-colors cursor-pointer"
                      onclick={`event.preventDefault(); event.stopPropagation(); window.open('${vendor.nostrUrl}', '_blank');`}
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="40 38 185 180">
                        <path d="M210.8 199.4c0 3.1-2.5 5.7-5.7 5.7h-68c-3.1 0-5.7-2.5-5.7-5.7v-15.5c.3-19 2.3-37.2 6.5-45.5 2.5-5 6.7-7.7 11.5-9.1 9.1-2.7 24.9-.9 31.7-1.2 0 0 20.4.8 20.4-10.7s-9.1-8.6-9.1-8.6c-10 .3-17.7-.4-22.6-2.4-8.3-3.3-8.6-9.2-8.6-11.2-.4-23.1-34.5-25.9-64.5-20.1-32.8 6.2.4 53.3.4 116.1v8.4c0 3.1-2.6 5.6-5.7 5.6H57.7c-3.1 0-5.7-2.5-5.7-5.7v-144c0-3.1 2.5-5.7 5.7-5.7h31.7c3.1 0 5.7 2.5 5.7 5.7 0 4.7 5.2 7.2 9 4.5 11.4-8.2 26-12.5 42.4-12.5 36.6 0 64.4 21.4 64.4 68.7v83.2ZM150 99.3c0-6.7-5.4-12.1-12.1-12.1s-12.1 5.4-12.1 12.1 5.4 12.1 12.1 12.1S150 106 150 99.3Z"/>
                      </svg>
                    </span>
                  )}
                  {vendor.xUrl && (
                    <span
                      class="text-gray-400 hover:text-gray-900 transition-colors cursor-pointer"
                      onclick={`event.preventDefault(); event.stopPropagation(); window.open('${vendor.xUrl}', '_blank');`}
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                      </svg>
                    </span>
                  )}
                </div>
              )}
            </div>
          </div>
        </a>
      );})}
    </div>
  )}

  <hr class="my-8 border-gray-200" />

  <h2>Prefer to Build Your Own?</h2>
  <p>
    Lightning Piggy is fully open source. Source the parts yourself and follow our
    step-by-step build guide.
  </p>

  <div class="not-prose mt-6">
    <Button href="/build" variant="outline">
      View Build Guide →
    </Button>
  </div>
</ContentLayout>
