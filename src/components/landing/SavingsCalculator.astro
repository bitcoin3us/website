          <path d="M313.386,124.225l-2.049,21.207h21.793c-4.096,11.116-12.869,14.771-22.084,14.771c-15.649,0-26.472-11.114-26.472-27.495c0-17.55,12.871-31.735,30.859-31.735c10.968,0,17.989,4.974,22.813,13.162l19.601-13.017c-9.216-18.427-26.034-24.132-41.391-24.132c-32.322,0-58.355,25.887-58.355,58.795c0,29.833,22.233,47.97,48.994,47.97c29.104,0,55.284-22.085,52.798-59.526H313.386z"/>
          <polygon points="407.437,119.836 389.446,78.448 361.223,78.448 392.519,143.093 387.984,182.287 413.726,182.287 418.26,143.093 463.157,78.448 433.322,78.448"/>
          <polygon points="19.73,0.845 13.395,60.808 49.375,60.808 50.896,47.21 29.781,47.21 34.595,0.845"/>
          <polygon points="57.652,60.808 72.516,60.808 78.852,0.845 63.987,0.845"/>
