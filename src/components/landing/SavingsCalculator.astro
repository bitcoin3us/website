---
import SectionHeading from '../ui/SectionHeading.astro';
---

<section class="py-14">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      title="Savings Calculator"
      subtitle="See how much savings your child could have with weekly zaps!"
    />

    <div class="mt-12 max-w-2xl mx-auto">
      <!-- Inputs -->
      <div class="grid sm:grid-cols-2 gap-6 mb-8">

        <!-- Weekly Amount -->
        <div>
          <label for="calc-amount" class="block text-sm font-semibold text-gray-900 mb-3">
            Weekly pocket money (USD)
          </label>
          <div class="flex flex-wrap gap-2 mb-3" id="amount-presets">
            <button type="button" data-amount="5"
              class="amount-preset px-4 py-2 rounded-full border-2 border-gray-200 text-gray-700 font-semibold text-sm hover:border-pink hover:text-pink transition-all cursor-pointer">$5</button>
            <button type="button" data-amount="10"
              class="amount-preset px-4 py-2 rounded-full border-2 border-pink bg-pink/5 text-pink font-semibold text-sm transition-all cursor-pointer">$10</button>
            <button type="button" data-amount="21"
              class="amount-preset px-4 py-2 rounded-full border-2 border-gray-200 text-gray-700 font-semibold text-sm hover:border-pink hover:text-pink transition-all cursor-pointer">$21</button>
            <button type="button" data-amount="50"
              class="amount-preset px-4 py-2 rounded-full border-2 border-gray-200 text-gray-700 font-semibold text-sm hover:border-pink hover:text-pink transition-all cursor-pointer">$50</button>
          </div>
          <div class="relative">
            <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 font-medium">$</span>
            <input
              type="number"
              id="calc-amount"
              min="1"
              step="1"
              value="10"
              class="w-full pl-8 pr-4 py-3 rounded-xl border border-gray-200 focus:border-pink focus:ring-2 focus:ring-pink/20 outline-none transition-all text-gray-900"
            />
          </div>
        </div>

        <!-- Years -->
        <div>
          <label for="calc-years" class="block text-sm font-semibold text-gray-900 mb-3">
            Saving for the previous (years)
          </label>
          <div class="flex flex-wrap gap-2 mb-3" id="years-presets">
            <button type="button" data-years="1"
              class="years-preset px-4 py-2 rounded-full border-2 border-gray-200 text-gray-700 font-semibold text-sm hover:border-pink hover:text-pink transition-all cursor-pointer">1</button>
            <button type="button" data-years="3"
              class="years-preset px-4 py-2 rounded-full border-2 border-gray-200 text-gray-700 font-semibold text-sm hover:border-pink hover:text-pink transition-all cursor-pointer">3</button>
            <button type="button" data-years="5"
              class="years-preset px-4 py-2 rounded-full border-2 border-gray-200 text-gray-700 font-semibold text-sm hover:border-pink hover:text-pink transition-all cursor-pointer">5</button>
            <button type="button" data-years="10"
              class="years-preset px-4 py-2 rounded-full border-2 border-pink bg-pink/5 text-pink font-semibold text-sm transition-all cursor-pointer">10</button>
          </div>
          <input
            type="number"
            id="calc-years"
            min="1"
            max="15"
            step="1"
            value="10"
            class="w-full px-4 py-3 rounded-xl border border-gray-200 focus:border-pink focus:ring-2 focus:ring-pink/20 outline-none transition-all text-gray-900"
          />
        </div>
      </div>

      <!-- Results Card -->
      <div class="relative bg-gray-50 rounded-2xl p-6 md:p-8 border border-gray-200 overflow-hidden">
        <div class="relative z-10 grid sm:grid-cols-2 gap-6">
          <!-- Total Sats -->
          <div>
            <p class="text-sm font-medium text-gray-500 mb-1">Total sats saved</p>
            <p id="calc-sats" class="text-3xl font-bold text-gray-900">—</p>
          </div>
          <!-- Current Value -->
          <div>
            <p class="text-sm font-medium text-gray-500 mb-1">Current USD value</p>
            <p id="calc-value" class="text-3xl font-bold text-gray-900">—</p>
          </div>
          <!-- Total Invested -->
          <div>
            <p class="text-sm font-medium text-gray-500 mb-1">Total invested</p>
            <p id="calc-invested" class="text-2xl font-bold text-gray-600">—</p>
          </div>
          <!-- Gain -->
          <div>
            <p class="text-sm font-medium text-gray-500 mb-1">Gain</p>
            <p id="calc-gain" class="text-2xl font-bold text-gray-600">—</p>
          </div>
        </div>

        <!-- Live indicator (hidden until API succeeds) -->
        <div id="calc-live" class="relative z-10 mt-4 flex items-center gap-1.5 hidden">
          <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
          <span class="text-xs text-gray-400">Live via mempool.space</span>
        </div>

        <!-- Watermark logo (bottom-right for screenshots) -->
        <svg class="absolute bottom-3 right-4 w-28 opacity-[0.08] pointer-events-none" viewBox="0 0 467.716 190.193" fill="currentColor" aria-hidden="true">
