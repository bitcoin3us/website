          <polygon points="199.715,60.808 206.048,0.845 191.184,0.845 188.734,24.239 167.873,24.239 170.323,0.845 155.457,0.845 149.124,60.808 163.987,60.808 166.438,37.834 187.299,37.834 184.849,60.808"/>
          <polygon points="212.384,14.443 225.305,14.443 220.492,60.808 235.356,60.808 240.171,14.443 253.346,14.443 254.866,0.845 213.82,0.845"/>
          <polygon points="274.882,25.169 275.389,25.169 294.225,60.808 309.344,60.808 315.678,0.845 300.813,0.845 297.097,36.486 296.59,36.486 277.671,0.845 262.553,0.845 256.302,60.808 271.166,60.808"/>
          <polygon points="334.005,60.808 340.339,0.845 325.476,0.845 319.141,60.808"/>
          <polygon points="384.175,36.486 365.257,0.845 350.138,0.845 343.887,60.808 358.753,60.808 362.47,25.169 362.976,25.169 381.812,60.808 396.929,60.808 403.265,0.845 388.397,0.845 384.682,36.486"/>
          <path d="M440.766,27.279l-1.185,12.247h12.584c-2.365,6.419-7.433,8.529-12.752,8.529c-9.038,0-15.289-6.417-15.289-15.879c0-10.136,7.433-18.327,17.823-18.327c6.334,0,10.387,2.872,13.176,7.603l11.316-7.517C461.119,3.295,451.406,0,442.538,0c-18.667,0-33.701,14.948-33.701,33.951c0,17.229,12.839,27.702,28.295,27.702c16.807,0,31.926-12.753,30.489-34.374H440.766z"/>
          <polygon points="100.869,72.858 88.083,134.914 102.32,134.914 91.088,190.193 143.175,122.871 124.154,122.871 146.968,72.858"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<script is:inline>
document.addEventListener('DOMContentLoaded', function () {
  var amountInput = document.getElementById('calc-amount');
  var yearsInput = document.getElementById('calc-years');
  var amountPresets = document.querySelectorAll('.amount-preset');
  var yearsPresets = document.querySelectorAll('.years-preset');

  var satsEl = document.getElementById('calc-sats');
  var valueEl = document.getElementById('calc-value');
  var investedEl = document.getElementById('calc-invested');
  var gainEl = document.getElementById('calc-gain');
  var liveEl = document.getElementById('calc-live');

  var weeklyPrices = null;
  var currentPrice = null;

  // --- Preset button logic ---
  function setActivePreset(buttons, activeBtn) {
    buttons.forEach(function (btn) {
      btn.classList.remove('border-pink', 'bg-pink/5', 'text-pink');
      btn.classList.add('border-gray-200', 'text-gray-700');
    });
    if (activeBtn) {
      activeBtn.classList.remove('border-gray-200', 'text-gray-700');
      activeBtn.classList.add('border-pink', 'bg-pink/5', 'text-pink');
    }
  }

  amountPresets.forEach(function (btn) {
    btn.addEventListener('click', function () {
      amountInput.value = btn.getAttribute('data-amount');
      setActivePreset(amountPresets, btn);
      recalculate();
    });
  });

  yearsPresets.forEach(function (btn) {
    btn.addEventListener('click', function () {
      yearsInput.value = btn.getAttribute('data-years');
      setActivePreset(yearsPresets, btn);
      recalculate();
    });
  });

  amountInput.addEventListener('input', function () {
    var val = amountInput.value;
    var matched = null;
    amountPresets.forEach(function (btn) {
      if (btn.getAttribute('data-amount') === val) matched = btn;
    });
    setActivePreset(amountPresets, matched);
    recalculate();
  });

  yearsInput.addEventListener('input', function () {
    var val = yearsInput.value;
    var matched = null;
    yearsPresets.forEach(function (btn) {
      if (btn.getAttribute('data-years') === val) matched = btn;
    });
    setActivePreset(yearsPresets, matched);
    recalculate();
  });

  // --- Number formatting ---
  function formatNumber(n) {
    return n.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  // --- Core DCA calculation ---
  function recalculate() {
    if (!weeklyPrices || !currentPrice) return;

    var amount = parseFloat(amountInput.value) || 0;
    var years = parseInt(yearsInput.value) || 0;

    if (amount <= 0 || years <= 0) {
      satsEl.textContent = '—';
      valueEl.textContent = '—';
      investedEl.textContent = '—';
      gainEl.textContent = '—';
      gainEl.className = 'text-2xl font-bold text-gray-600';
      return;
    }

    // Find weeks within the time range
    var now = Math.floor(Date.now() / 1000);
    var startTime = now - (years * 365.25 * 24 * 60 * 60);

    var totalSats = 0;
    var weeksCount = 0;

    for (var i = 0; i < weeklyPrices.length; i++) {
      if (weeklyPrices[i].time >= startTime && weeklyPrices[i].time <= now) {
        totalSats += (amount / weeklyPrices[i].price) * 100000000;
        weeksCount++;
      }
    }

    var totalInvested = amount * weeksCount;
    var currentValue = (totalSats / 100000000) * currentPrice;
    var gain = currentValue - totalInvested;
    var gainPct = totalInvested > 0 ? ((gain / totalInvested) * 100) : 0;

    totalSats = Math.round(totalSats);

    // Update display
    satsEl.innerHTML = formatNumber(totalSats) + ' <span class="text-lg font-semibold text-gray-500">sats</span>';
    valueEl.textContent = '$' + formatNumber(Math.round(currentValue));
    investedEl.textContent = '$' + formatNumber(Math.round(totalInvested));

    if (gain >= 0) {
      gainEl.textContent = '+' + Math.round(gainPct) + '% (+$' + formatNumber(Math.round(gain)) + ')';
      gainEl.className = 'text-2xl font-bold text-green-600';
    } else {
      gainEl.textContent = Math.round(gainPct) + '% (-$' + formatNumber(Math.round(Math.abs(gain))) + ')';
      gainEl.className = 'text-2xl font-bold text-red-500';
    }
  }

  // --- Fetch weekly price data ---
  fetch('/.netlify/functions/btc-weekly-prices')
    .then(function (res) {
      if (!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    })
    .then(function (data) {
      weeklyPrices = data.weeks;
      currentPrice = data.currentPrice;
      recalculate();
      if (liveEl) liveEl.classList.remove('hidden');
    })
    .catch(function (err) {
      console.warn('Savings calculator fetch failed:', err);
    });
});
</script>
