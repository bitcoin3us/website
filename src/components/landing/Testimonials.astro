---
import SectionHeading from '../ui/SectionHeading.astro';
import testimonialsData from '../../data/testimonials.json';

const { testimonials = [] } = testimonialsData;

// Only show if we have testimonials
const hasTestimonials = testimonials.length > 0;

// Platform icon SVGs
const platformIcons: Record<string, { svg: string; color: string }> = {
  nostr: {
    svg: `<path d="M210.8 199.4c0 3.1-2.5 5.7-5.7 5.7h-68c-3.1 0-5.7-2.5-5.7-5.7v-15.5c.3-19 2.3-37.2 6.5-45.5 2.5-5 6.7-7.7 11.5-9.1 9.1-2.7 24.9-.9 31.7-1.2 0 0 20.4.8 20.4-10.7s-9.1-8.6-9.1-8.6c-10 .3-17.7-.4-22.6-2.4-8.3-3.3-8.6-9.2-8.6-11.2-.4-23.1-34.5-25.9-64.5-20.1-32.8 6.2.4 53.3.4 116.1v8.4c0 3.1-2.6 5.6-5.7 5.6H57.7c-3.1 0-5.7-2.5-5.7-5.7v-144c0-3.1 2.5-5.7 5.7-5.7h31.7c3.1 0 5.7 2.5 5.7 5.7 0 4.7 5.2 7.2 9 4.5 11.4-8.2 26-12.5 42.4-12.5 36.6 0 64.4 21.4 64.4 68.7v83.2ZM150 99.3c0-6.7-5.4-12.1-12.1-12.1s-12.1 5.4-12.1 12.1 5.4 12.1 12.1 12.1S150 106 150 99.3Z"/>`,
    color: 'hover:text-purple-600'
  },
  x: {
    svg: `<path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>`,
    color: 'hover:text-gray-900'
  },
  telegram: {
    svg: `<path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>`,
    color: 'hover:text-blue-500'
  },
  youtube: {
    svg: `<path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>`,
    color: 'hover:text-red-600'
  },
  other: {
    svg: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>`,
    color: 'hover:text-blue-600'
  }
};
---

{hasTestimonials && (
<section class="py-20 bg-gray-50">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      title="What People Are Saying"
      subtitle="Hear from the Lightning Piggy community around the world."
    />

    <!-- Carousel Container -->
    <div class="relative mt-12">
      <!-- Cards Container -->
      <div
        id="testimonials-carousel"
        class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 -mx-4 px-4 scrollbar-hide"
        style="scrollbar-width: none; -ms-overflow-style: none;"
      >
        {testimonials.map((testimonial, index) => (
          <div
            class="testimonial-card snap-center flex-shrink-0 w-[300px] sm:w-[340px] bg-white rounded-2xl p-6 shadow-lg hover:shadow-xl transition-shadow relative"
            data-index={index}
          >
            <!-- Source Platform Icon (top-right) -->
            <a
              href={testimonial.sourceUrl}
              target="_blank"
              rel="noopener noreferrer"
              class={`absolute top-4 right-4 text-gray-400 transition-colors ${platformIcons[testimonial.sourcePlatform]?.color || platformIcons.other.color}`}
              title={`View on ${testimonial.sourcePlatform}`}
            >
              {testimonial.sourcePlatform === 'other' ? (
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={platformIcons.other.svg} />
                </svg>
              ) : testimonial.sourcePlatform === 'nostr' ? (
                <svg class="w-5 h-5" fill="currentColor" viewBox="40 38 185 180">
                  <Fragment set:html={platformIcons.nostr.svg} />
                </svg>
              ) : (
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                  <Fragment set:html={platformIcons[testimonial.sourcePlatform]?.svg || platformIcons.other.svg} />
                </svg>
              )}
            </a>

            <!-- Profile Picture -->
            <div class="flex items-start gap-4 mb-4">
              <div class="w-14 h-14 rounded-full bg-gray-100 overflow-hidden flex-shrink-0 flex items-center justify-center">
                {testimonial.profilePic ? (
                  <img
                    src={testimonial.profilePic}
                    alt={testimonial.name}
                    class="w-full h-full object-cover"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
                ) : null}
                <div
                  class="w-full h-full bg-pink/10 flex items-center justify-center text-pink text-xl font-bold"
                  style={testimonial.profilePic ? "display: none;" : ""}
                >
                  {testimonial.name.charAt(0).toUpperCase()}
                </div>
              </div>
              <div class="pt-2">
                <h4 class="font-semibold text-gray-900">{testimonial.name}</h4>
              </div>
            </div>

            <!-- Quote -->
            <blockquote class="text-gray-600 italic leading-relaxed">
              <span class="text-pink text-2xl leading-none">"</span>
              {testimonial.quote}
              <span class="text-pink text-2xl leading-none">"</span>
            </blockquote>
          </div>
        ))}
      </div>

      <!-- Navigation Dots -->
      {testimonials.length > 1 && (
        <div class="flex justify-center gap-2 mt-6" id="testimonials-dots">
          {testimonials.map((_, index) => (
            <button
              class={`w-2 h-2 rounded-full transition-colors ${index === 0 ? 'bg-pink' : 'bg-gray-300'}`}
              data-index={index}
              aria-label={`Go to testimonial ${index + 1}`}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</section>
)}

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  // Auto-scroll carousel
  const carousel = document.getElementById('testimonials-carousel');
  const dots = document.querySelectorAll('#testimonials-dots button');
  const cards = document.querySelectorAll('.testimonial-card');

  if (carousel && cards.length > 1) {
    let currentIndex = 0;
    let autoScrollInterval: ReturnType<typeof setInterval>;
    let isPaused = false;

    const scrollToIndex = (index: number) => {
      const card = cards[index] as HTMLElement;
      if (card) {
        const containerRect = carousel.getBoundingClientRect();
        const cardRect = card.getBoundingClientRect();
        const scrollLeft = card.offsetLeft - (containerRect.width / 2) + (cardRect.width / 2);
        carousel.scrollTo({ left: scrollLeft, behavior: 'smooth' });
        currentIndex = index;
        updateDots();
      }
    };

    const updateDots = () => {
      dots.forEach((dot, index) => {
        dot.classList.toggle('bg-pink', index === currentIndex);
        dot.classList.toggle('bg-gray-300', index !== currentIndex);
      });
    };

    const autoScroll = () => {
      if (!isPaused) {
        currentIndex = (currentIndex + 1) % cards.length;
        scrollToIndex(currentIndex);
      }
    };

    // Start auto-scroll
    autoScrollInterval = setInterval(autoScroll, 5000);

    // Pause on hover
    carousel.addEventListener('mouseenter', () => {
      isPaused = true;
    });

    carousel.addEventListener('mouseleave', () => {
      isPaused = false;
    });

    // Dot click handlers
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        scrollToIndex(index);
      });
    });

    // Update current index on manual scroll
    carousel.addEventListener('scroll', () => {
      const containerCenter = carousel.scrollLeft + carousel.clientWidth / 2;
      let closestIndex = 0;
      let closestDistance = Infinity;

      cards.forEach((card, index) => {
        const cardElement = card as HTMLElement;
        const cardCenter = cardElement.offsetLeft + cardElement.clientWidth / 2;
        const distance = Math.abs(containerCenter - cardCenter);
        if (distance < closestDistance) {
          closestDistance = distance;
          closestIndex = index;
        }
      });

      if (closestIndex !== currentIndex) {
        currentIndex = closestIndex;
        updateDots();
      }
    });
  }
</script>
