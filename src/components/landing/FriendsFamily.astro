---
import SectionHeading from '../ui/SectionHeading.astro';
import partnersData from '../../data/partners.json';

const { communitySponsors = [], educationPartners = [], technologyPartners = [], appearances = [], inTheNews = [] } = partnersData;

// Check if we have any partners to show
const hasPartners = communitySponsors.length > 0 || educationPartners.length > 0 || technologyPartners.length > 0 || appearances.length > 0 || inTheNews.length > 0;

// Helper to check if URL is a personal website (not a social profile)
function isWebsiteUrl(url?: string): boolean {
  if (!url) return false;
  // Social profile patterns that should NOT show globe icon
  const socialPatterns = [
    /twitter\.com\//i,
    /x\.com\//i,
    /njump\.me\//i,
    /github\.com\//i,
    /nostr\.band\//i,
    /primal\.net\//i,
  ];
  return !socialPatterns.some(pattern => pattern.test(url));
}

// Reusable card component markup
const renderCard = (partner: any) => partner;
---

{hasPartners && (
<section class="py-20 bg-white">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <SectionHeading
      title="Friends & Family"
      subtitle="The amazing projects, companies, and creators supporting the Lightning Piggy project."
    />

    <!-- Community Sponsors -->
    {communitySponsors.length > 0 && (
      <div class="mt-12">
        <h3 class="text-xl font-bold text-gray-900 mb-2 text-center">Community Sponsors ❤️</h3>
        <p class="text-gray-600 mb-6 text-center">Generous supporters helping bring Bitcoin education to the next generation.</p>
        <div class="flex flex-wrap justify-center gap-4">
          {communitySponsors.map((partner) => (
            <a
              href={partner.url}
              target="_blank"
              rel="noopener noreferrer"
              class="bg-white rounded-xl p-4 text-center hover:shadow-lg transition-all group w-40 sm:w-44"
            >
              <div class="w-24 h-24 mx-auto mb-3 rounded-full bg-gray-100 overflow-hidden flex items-center justify-center">
                {partner.logo ? (
                  <img
                    src={partner.logo}
                    alt={partner.name}
                    class="w-full h-full object-cover"
                    onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                  />
                ) : null}
                <div class="w-full h-full bg-pink/10 flex items-center justify-center text-pink text-2xl font-bold" style={partner.logo ? "display: none;" : ""}>
