      <div class="mt-12">
        <h3 class="text-xl font-bold text-gray-900 mb-2 text-center">In the News</h3>
        <p class="text-gray-600 mb-6 text-center">Publications and articles featuring Lightning Piggy.</p>
        <div class="flex flex-wrap justify-center gap-4">
          {inTheNews.map((partner) => (
