---
// Live counter showing how much purchasing power USD has lost against Bitcoin
// over the last 10 years. Falls back to static values if the API is unavailable.
---

<div id="btc-power-loss" class="md:float-right md:ml-6 md:mb-2 md:w-56 bg-gray-50 rounded-2xl p-5 border border-gray-200">
  <!-- Header -->
  <div class="flex items-center gap-1.5 mb-2">
    <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" />
    </svg>
    <span class="text-xs font-medium text-red-500">USD vs Bitcoin</span>
  </div>

  <!-- Hero stat -->
  <div class="flex items-baseline gap-0.5 mb-0.5">
    <span class="text-xs text-gray-400 self-start mt-2">~</span>
    <span id="power-loss-pct" class="text-5xl font-bold text-gray-900">99</span>
    <span class="text-xl font-bold text-gray-900">%</span>
  </div>
  <p class="text-gray-500 text-sm font-medium mb-3">purchasing power lost in 10 years</p>

  <!-- Calculation detail: date — price per line -->
  <div id="power-loss-detail" class="text-xs text-gray-400 space-y-0.5">
    <p><span id="date-then">Feb 2016</span> — 1 BTC = <span id="price-then">$421</span></p>
    <p><span id="date-now">Feb 2026</span> — 1 BTC = <span id="price-now">$66,132</span></p>
  </div>

  <!-- Live indicator (hidden until API succeeds) -->
  <div id="power-loss-live" class="mt-2 flex items-center gap-1.5 hidden">
    <span class="w-1.5 h-1.5 bg-green-500 rounded-full animate-pulse"></span>
    <span class="text-xs text-gray-400">Live via mempool.space</span>
  </div>
</div>

<script is:inline>
document.addEventListener('DOMContentLoaded', function () {
  fetch('/.netlify/functions/btc-purchasing-power')
    .then(function (res) {
      if (!res.ok) throw new Error('HTTP ' + res.status);
      return res.json();
    })
    .then(function (data) {
      // Update percentage (rounded to whole number)
      var pctEl = document.getElementById('power-loss-pct');
      if (pctEl && data.percentage) {
        pctEl.textContent = Math.round(data.percentage);
      }

      // Update price details
      var thenEl = document.getElementById('price-then');
      var nowEl = document.getElementById('price-now');
      if (thenEl && data.historicalPrice) {
        thenEl.textContent = '$' + data.historicalPrice.toLocaleString();
      }
      if (nowEl && data.currentPrice) {
        nowEl.textContent = '$' + data.currentPrice.toLocaleString();
      }

      // Update date labels
      var dateThenEl = document.getElementById('date-then');
      var dateNowEl = document.getElementById('date-now');
      if (dateThenEl && data.historicalDateLabel) {
        dateThenEl.textContent = data.historicalDateLabel;
      }
      if (dateNowEl && data.currentDateLabel) {
        dateNowEl.textContent = data.currentDateLabel;
      }

      // Show the live indicator
      var liveEl = document.getElementById('power-loss-live');
      if (liveEl) liveEl.classList.remove('hidden');
    })
    .catch(function (err) {
      console.warn('BTC purchasing power fetch failed, using fallback:', err);
    });
});
</script>
